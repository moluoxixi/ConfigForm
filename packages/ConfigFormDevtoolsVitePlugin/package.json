{
  "name": "@moluoxixi/config-form-devtools-vite-plugin",
  "type": "module",
  "version": "0.1.0",
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.app.json --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "vue-tsc -p tsconfig.test.json --noEmit"
  },
  "peerDependencies": {
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@babel/parser": "catalog:dev",
    "@vue/compiler-sfc": "catalog:dev",
    "magic-string": "catalog:dev"
  },
  "devDependencies": {
    "@types/node": "catalog:type",
    "@vitest/coverage-v8": "catalog:dev",
    "happy-dom": "catalog:dev",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vue-tsc": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
