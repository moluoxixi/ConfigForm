{
  "name": "@config-form/core",
  "version": "0.1.0",
  "type": "module",
  "files": ["dist", "src/styles"],
  "main": "./dist/config-form-core.js",
  "module": "./dist/config-form-core.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/config-form-core.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/styles/index.scss",
    "./styles/*": "./src/styles/*"
  },
  "sideEffects": ["**/*.scss", "**/*.css"],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:dev",
    "sass": "catalog:dev",
    "vite": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "^2.2.8",
    "zod": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
