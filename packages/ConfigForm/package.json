{
  "name": "@moluoxixi/config-form",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist",
    "styles",
    "src/styles"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./src/styles/index.scss",
    "./styles/*": "./src/styles/*"
  },
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.app.json --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:dev",
    "sass": "catalog:dev",
    "vite": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "^2.2.8",
    "zod": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}