{
  "name": "@moluoxixi/config-form",
  "type": "module",
  "version": "0.1.0",
  "sideEffects": [
    "**/*.scss",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "source": "./index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./src/styles/index.scss",
    "./styles/*": "./src/styles/*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/styles",
    "styles"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.app.json --declaration --emitDeclarationOnly --outDir dist && node scripts/rewrite-dts-aliases.mjs",
    "dev": "vite build --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "catalog:dev",
    "sass": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev",
    "vue": "catalog:build",
    "vue-tsc": "catalog:dev",
    "zod": "catalog:dev"
  },
  "publishConfig": {
    "access": "public"
  }
}
